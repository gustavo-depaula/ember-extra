            }
          ]
        ]
      }
    }
  },
  "postcommunion": {
    "body": {
      "plain": {
        "fr": "Dieu tout-puissant, que l’action du sacrement divin nous apporte lumière et ferveur en cette fête de sainte Louise de Marillac, pour que nous brûlions toujours du désir de la sainteté et fassions en abondance toute sorte de bien. Par le Christ, notre Seigneur."
      },
      "lines": {
        "fr": [
          [
            {
              "type": "text",
              "text": "Dieu tout-puissant,"
            }
          ],
          [
            {
              "type": "text",
              "text": "que l’action du sacrement divin"
            }
          ],
          [
            {
              "type": "text",
              "text": "nous apporte lumière et ferveur"
            }
          ],
          [
            {
              "type": "text",
              "text": "en cette fête de sainte Louise de Marillac,"
            }
          ],
          [
            {
              "type": "text",
              "text": "pour que nous brûlions toujours du désir de la sainteté"
            }
          ],
          [
            {
              "type": "text",
              "text": "et fassions en abondance toute sorte de bien."
            }
          ],
          [
            {
              "type": "text",
              "text": "Par le Christ, notre Seigneur."
            }
          ]
        ]
      }
    }
  },
