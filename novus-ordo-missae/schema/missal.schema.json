{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/your-org/missal-json/schema/missal.schema.json",
  "title": "Missale Romanum corpus",
  "description": "Domain-shaped JSON schema for the Roman Missal (Ordinary Form) extracted from pedropasinn/Missale_romanum. Languages: Latin (la), Castilian (es), English (en), Brazilian Portuguese (pt-BR), Italian (it), French (fr), German (de).",
  "type": "object",
  "$defs": {
    "Language": {
      "type": "string",
      "enum": [
        "la",
        "es",
        "en",
        "pt-BR",
        "it",
        "fr",
        "de"
      ]
    },
    "Localized": {
      "description": "A field localized into one or more BCP-47 language tags. All tags optional.",
      "type": "object",
      "properties": {
        "la": {
          "type": "string"
        },
        "es": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "pt-BR": {
          "type": "string"
        },
        "it": {
          "type": "string"
        },
        "fr": {
          "type": "string"
        },
        "de": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "SegmentType": {
      "description": "Inline segment kind. Pure semantic taxonomy — no presentational types.",
      "type": "string",
      "enum": [
        "text",
        "rubric",
        "reference",
        "italic",
        "response",
        "signOfCross",
        "dropCap"
      ]
    },
    "Segment": {
      "type": "object",
      "properties": {
        "type": {
          "$ref": "#/$defs/SegmentType"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "Line": {
      "description": "A single line in a prayer body. An ordered list of inline segments.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Segment"
      },
      "minItems": 1
    },
    "RichText": {
      "description": "A localized rich-text body. `plain` is the joined text per language; `lines` is the line-broken segment structure per language.",
      "type": "object",
      "properties": {
        "plain": {
          "$ref": "#/$defs/Localized"
        },
        "lines": {
          "description": "Per-language list of lines. Lines preserve the source's prayer-line formatting.",
          "type": "object",
          "properties": {
            "la": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Line"
              }
            },
            "es": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Line"
              }
            },
            "en": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Line"
              }
            },
            "pt-BR": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Line"
              }
            },
            "it": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Line"
              }
            },
            "fr": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Line"
              }
            },
            "de": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Line"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "plain"
          ]
        },
        {
          "required": [
            "lines"
          ]
        }
      ]
    },
    "Antiphon": {
      "type": "object",
      "properties": {
        "citation": {
          "$ref": "#/$defs/Localized"
        },
        "body": {
          "$ref": "#/$defs/RichText"
        }
      },
      "anyOf": [
        {
          "required": [
            "body"
          ]
        },
        {
          "required": [
            "citation"
          ]
        }
      ],
      "additionalProperties": false
    },
    "PrayerOption": {
      "description": "A single body+citation option for a prayer slot. Used both standalone (most slots) and as an item inside `Prayer.alternatives`.",
      "type": "object",
      "properties": {
        "body": { "$ref": "#/$defs/RichText" },
        "label": { "$ref": "#/$defs/Localized" },
        "citation": { "$ref": "#/$defs/Localized" }
      },
      "required": ["body"],
      "additionalProperties": false
    },
    "Prayer": {
      "description": "A prayer slot — collect, postcommunion, gospelAcclamation, etc. When the missal supplies a single option (the common case), the slot has body+citation directly. When multiple options are supplied (e.g. All Souls' 11 gospel acclamations, Sacred Heart's 2 cycle-B options), all of them live inside `alternatives` and the slot itself carries no body — consumers iterate the array.",
      "oneOf": [
        { "$ref": "#/$defs/PrayerOption" },
        {
          "type": "object",
          "properties": {
            "alternatives": {
              "type": "array",
              "minItems": 2,
              "items": { "$ref": "#/$defs/PrayerOption" }
            }
          },
          "required": ["alternatives"],
          "additionalProperties": false
        }
      ]
    },
    "PrefaceRef": {
      "description": "A pointer to one or more prefaces in library/prefaces.json. The first entry is the proper preface; subsequent entries are alternatives the priest may choose.",
      "type": "object",
      "properties": {
        "prefaceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^preface\\."
          }
        },
        "label": {
          "$ref": "#/$defs/Localized"
        },
        "excerpt": {
          "$ref": "#/$defs/Localized"
        }
      },
      "required": [
        "prefaceRefs"
      ],
      "additionalProperties": false
    },
    "ReadingOption": {
      "description": "A single reading option (label, introduction, citation, body, conclusion, response). Used standalone for the common case and as an item inside `Reading.alternatives`.",
      "type": "object",
      "properties": {
        "label": { "$ref": "#/$defs/Localized" },
        "introduction": { "$ref": "#/$defs/Localized" },
        "citation": { "$ref": "#/$defs/Localized" },
        "summary": { "$ref": "#/$defs/Localized" },
        "body": { "$ref": "#/$defs/RichText" },
        "conclusion": { "$ref": "#/$defs/Localized" },
        "response": { "$ref": "#/$defs/Prayer" }
      },
      "anyOf": [
        { "required": ["body"] },
        { "required": ["citation"] },
        { "required": ["label"] }
      ],
      "additionalProperties": false
    },
    "Reading": {
      "description": "A reading slot (firstReading, secondReading, gospel). When the lectionary supplies a single form, the slot has body+citation directly. When multiple forms are supplied (e.g. brevior/longior gospel choices on Lent W5 Sunday A, Easter Sunday, common-of-saints Mass), all of them live inside `alternatives` and the slot carries no body — consumers iterate the array.",
      "oneOf": [
        { "$ref": "#/$defs/ReadingOption" },
        {
          "type": "object",
          "properties": {
            "alternatives": {
              "type": "array",
              "minItems": 2,
              "items": { "$ref": "#/$defs/ReadingOption" }
            }
          },
          "required": ["alternatives"],
          "additionalProperties": false
        }
      ]
    },
    "ResponsorialPsalm": {
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/RichText"
        },
        "label": {
          "$ref": "#/$defs/Localized"
        },
        "citation": {
          "$ref": "#/$defs/Localized"
        }
      },
      "required": [
        "body"
      ],
      "additionalProperties": false
    },
    "ReadingSet": {
      "type": "object",
      "properties": {
        "firstReading": {
          "$ref": "#/$defs/Reading"
        },
        "responsorialPsalm": {
          "$ref": "#/$defs/ResponsorialPsalm"
        },
        "secondReading": {
          "$ref": "#/$defs/Reading"
        },
        "sequentia": {
          "description": "Easter Sunday and Pentecost only: Victimae Paschali laudes / Veni Sancte Spiritus. Falls between the second reading and the gospel acclamation.",
          "$ref": "#/$defs/Reading"
        },
        "gospelAcclamation": {
          "$ref": "#/$defs/Prayer"
        },
        "gospel": {
          "$ref": "#/$defs/Reading"
        }
      },
      "additionalProperties": false
    },
    "Readings": {
      "description": "Tree by lectionary cycle: A/B/C for Sundays, I/II for weekdays, default when no cycle.",
      "type": "object",
      "properties": {
        "A": {
          "$ref": "#/$defs/ReadingSet"
        },
        "B": {
          "$ref": "#/$defs/ReadingSet"
        },
        "C": {
          "$ref": "#/$defs/ReadingSet"
        },
        "I": {
          "$ref": "#/$defs/ReadingSet"
        },
        "II": {
          "$ref": "#/$defs/ReadingSet"
        },
        "default": {
          "$ref": "#/$defs/ReadingSet"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "Section": {
      "description": "A node in a special-rite content tree. Either a sub-section (with heading) or a leaf block (with body).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "section"
            },
            "level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 6
            },
            "heading": {
              "$ref": "#/$defs/Localized"
            },
            "content": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Section"
              }
            }
          },
          "required": [
            "type",
            "heading"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "block"
            },
            "body": {
              "$ref": "#/$defs/RichText"
            }
          },
          "required": [
            "type",
            "body"
          ],
          "additionalProperties": false
        }
      ]
    },
    "Part": {
      "description": "A typed part of a special rite. Always has a heading and a content tree; some rites add typed sub-fields like `solemnIntercessions`, `oldTestamentReadings`, etc.",
      "type": "object",
      "properties": {
        "heading": {
          "$ref": "#/$defs/Localized"
        },
        "content": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Section"
          }
        },
        "solemnIntercessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SolemnIntercession"
          }
        },
        "oldTestamentReadings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OTReadingUnit"
          }
        },
        "renewalOfBaptismalPromises": {
          "$ref": "#/$defs/RenewalOfBaptismalPromises"
        }
      },
      "required": [
        "content"
      ],
      "additionalProperties": false
    },
    "SolemnIntercession": {
      "description": "One of the ten Solemn Intercessions of Good Friday's Liturgy of the Word.",
      "type": "object",
      "properties": {
        "type": {
          "const": "solemn-intercession"
        },
        "ordinal": {
          "type": "string",
          "pattern": "^[IVX]+$"
        },
        "forWhom": {
          "$ref": "#/$defs/Localized"
        },
        "invitation": {
          "$ref": "#/$defs/Localized"
        },
        "silenceRubric": {
          "$ref": "#/$defs/Localized"
        },
        "collect": {
          "$ref": "#/$defs/Localized"
        },
        "response": {
          "$ref": "#/$defs/Localized"
        }
      },
      "required": [
        "type",
        "ordinal",
        "forWhom"
      ],
      "additionalProperties": false
    },
    "OTReadingUnit": {
      "description": "One of the seven Old Testament reading units of the Easter Vigil's Liturgy of the Word: a rubric describing the reading + the proper Collect (with optional alternative).",
      "type": "object",
      "properties": {
        "type": {
          "const": "ot-reading-unit"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "rubric": {
          "$ref": "#/$defs/RichText"
        },
        "collect": {
          "$ref": "#/$defs/RichText"
        },
        "alternativeCollect": {
          "$ref": "#/$defs/RichText"
        }
      },
      "required": [
        "type",
        "ordinal"
      ],
      "additionalProperties": false
    },
    "RenewalOfBaptismalPromises": {
      "description": "The Q&A exchange of the Easter Vigil's Renewal of Baptismal Promises.",
      "type": "object",
      "properties": {
        "questions": {
          "description": "Ordered list of priest/people exchanges, per language.",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              },
              "required": [
                "role",
                "text"
              ],
              "additionalProperties": false
            }
          }
        }
      },
      "required": [
        "questions"
      ],
      "additionalProperties": false
    },
    "Mass": {
      "description": "A Mass formulary or special-rite liturgy.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*(\\.[a-z0-9][a-z0-9-]*)+$"
        },
        "group": {
          "type": "string",
          "enum": [
            "tempore",
            "sanctorale",
            "common",
            "ritual",
            "votive"
          ]
        },
        "rite": {
          "type": "string",
          "enum": [
            "mass",
            "mass-with-procession",
            "chrism-mass",
            "lords-supper",
            "celebration-of-the-passion",
            "easter-vigil"
          ]
        },
        "season": {
          "type": "string",
          "enum": [
            "advent",
            "christmas",
            "lent",
            "holy-week",
            "easter",
            "ordinary-time",
            "solemnity"
          ]
        },
        "weekIndex": {
          "type": "integer",
          "minimum": 0,
          "maximum": 34,
          "description": "0 for the days from Ash Wednesday through the Saturday before the First Sunday of Lent."
        },
        "weekday": {
          "type": "string",
          "enum": [
            "sunday",
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday",
            "saturday"
          ]
        },
        "date": {
          "type": "object",
          "properties": {
            "month": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12
            },
            "day": {
              "type": "integer",
              "minimum": 1,
              "maximum": 31
            }
          },
          "required": [
            "month",
            "day"
          ],
          "additionalProperties": false
        },
        "movable": {
          "type": "boolean",
          "description": "True for movable feasts whose source day-id encodes a non-fixed position (Sunday after Trinity, etc.)."
        },
        "movableCode": {
          "type": "string",
          "description": "Original source day-id for movable feasts."
        },
        "movableMonthAnchor": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99,
          "description": "Month near which the movable feast typically falls. 99 = unanchored (entirely movable, e.g. Pentecost-relative)."
        },
        "undated": {
          "type": "boolean"
        },
        "ordinal": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "description": "Regional scope for sanctorale (e.g. 'Brazil', 'Argentina', 'Africa', 'France', 'Religious Orders')."
        },
        "subgroup": {
          "type": "string",
          "description": "Within common/ritual/votive groups (e.g. 'martyrs', 'for-the-dead')."
        },
        "title": {
          "$ref": "#/$defs/Localized"
        },
        "description": {
          "$ref": "#/$defs/Localized"
        },
        "rank": {
          "type": "string",
          "enum": [
            "solemnity",
            "feast",
            "memorial",
            "optional-memorial"
          ]
        },
        "rankLocalized": {
          "$ref": "#/$defs/Localized"
        },
        "liturgicalColor": {
          "type": "string",
          "enum": [
            "white",
            "red",
            "green",
            "violet",
            "rose",
            "black"
          ]
        },
        "entranceAntiphon": {
          "$ref": "#/$defs/Antiphon"
        },
        "penitentialAct": {
          "$ref": "#/$defs/Prayer"
        },
        "gloriaInstruction": {
          "$ref": "#/$defs/Prayer"
        },
        "collect": {
          "$ref": "#/$defs/Prayer"
        },
        "creedInstruction": {
          "$ref": "#/$defs/Prayer"
        },
        "readings": {
          "$ref": "#/$defs/Readings"
        },
        "processionGospel": {
          "$ref": "#/$defs/Readings",
          "description": "Palm Sunday only — the Gospel of the Lord's Entrance into Jerusalem read at the procession, separate from the Passion Gospel of the Mass."
        },
        "prayerOverOfferings": {
          "$ref": "#/$defs/Prayer"
        },
        "preface": {
          "oneOf": [
            {
              "$ref": "#/$defs/Prayer"
            },
            {
              "$ref": "#/$defs/PrefaceRef"
            }
          ]
        },
        "communionAntiphon": {
          "$ref": "#/$defs/Antiphon"
        },
        "postcommunion": {
          "$ref": "#/$defs/Prayer"
        },
        "prayerOverPeople": {
          "$ref": "#/$defs/Prayer"
        },
        "parts": {
          "description": "Special-rite typed parts (only present when rite ≠ \"mass\").",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/Part"
          }
        },
        "alternatives": {
          "description": "Additional celebrations sharing this date — different optional saints, alternative formularies of the same celebration (All Souls), or vigil/day pairs (Assumption). The root mass is the day's primary celebration; each entry here is a sibling option the priest may use instead.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/MassAlternative"
          }
        }
      },
      "required": [
        "id",
        "group"
      ],
      "additionalProperties": false
    },
    "MassAlternative": {
      "description": "A sibling Mass option nested inside a parent Mass. Inherits id/group/date/scope from the parent; carries its own title, rank, color, prayers, and readings.",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Stable kebab-case slug for this alternative within its parent (e.g. 'sebastian'). When the parent and alternatives share a celebration, suffixed with '-form-2', '-form-3' (e.g. 'all-souls-form-2')."
        },
        "title": { "$ref": "#/$defs/Localized" },
        "description": { "$ref": "#/$defs/Localized" },
        "rank": {
          "type": "string",
          "enum": ["solemnity", "feast", "memorial", "optional-memorial"]
        },
        "rankLocalized": { "$ref": "#/$defs/Localized" },
        "liturgicalColor": {
          "type": "string",
          "enum": ["white", "red", "green", "violet", "rose", "black"]
        },
        "entranceAntiphon": { "$ref": "#/$defs/Antiphon" },
        "penitentialAct": { "$ref": "#/$defs/Prayer" },
        "gloriaInstruction": { "$ref": "#/$defs/Prayer" },
        "collect": { "$ref": "#/$defs/Prayer" },
        "creedInstruction": { "$ref": "#/$defs/Prayer" },
        "readings": { "$ref": "#/$defs/Readings" },
        "prayerOverOfferings": { "$ref": "#/$defs/Prayer" },
        "preface": {
          "oneOf": [
            { "$ref": "#/$defs/Prayer" },
            { "$ref": "#/$defs/PrefaceRef" }
          ]
        },
        "communionAntiphon": { "$ref": "#/$defs/Antiphon" },
        "postcommunion": { "$ref": "#/$defs/Prayer" },
        "prayerOverPeople": { "$ref": "#/$defs/Prayer" }
      },
      "required": ["key", "title"],
      "additionalProperties": false
    },
    "Preface": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^preface\\."
        },
        "ordinal": {
          "type": "string"
        },
        "title": {
          "$ref": "#/$defs/Localized"
        },
        "body": {
          "$ref": "#/$defs/RichText"
        }
      },
      "required": [
        "id",
        "body"
      ],
      "additionalProperties": false
    },
    "EucharisticPrayer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^eucharistic-prayer\\."
        },
        "title": {
          "$ref": "#/$defs/Localized"
        },
        "body": {
          "$ref": "#/$defs/RichText"
        }
      },
      "required": [
        "id",
        "body"
      ],
      "additionalProperties": false
    },
    "OrdinaryPart": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ordinary\\."
        },
        "title": {
          "$ref": "#/$defs/Localized"
        },
        "body": {
          "$ref": "#/$defs/RichText"
        }
      },
      "required": [
        "id",
        "body"
      ],
      "additionalProperties": false
    },
    "SaintEntry": {
      "description": "An entry in the focused saints catalog (saints.json). Subset of a Mass — date, title, rank, description; no prayer bodies.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^sanctorale\\."
        },
        "date": {
          "type": "object",
          "properties": {
            "month": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12
            },
            "day": {
              "type": "integer",
              "minimum": 1,
              "maximum": 31
            }
          },
          "required": [
            "month",
            "day"
          ]
        },
        "scope": {
          "type": "string"
        },
        "title": {
          "$ref": "#/$defs/Localized"
        },
        "rank": {
          "type": "string",
          "enum": [
            "solemnity",
            "feast",
            "memorial",
            "optional-memorial"
          ]
        },
        "rankLocalized": {
          "$ref": "#/$defs/Localized"
        },
        "description": {
          "$ref": "#/$defs/Localized"
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": false
    },
    "CalendarEntry": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "$ref": "#/$defs/Localized"
        },
        "season": {
          "type": "string"
        },
        "weekIndex": {
          "type": "integer"
        },
        "weekday": {
          "type": "string"
        },
        "date": {
          "type": "object",
          "properties": {
            "month": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12
            },
            "day": {
              "type": "integer",
              "minimum": 1,
